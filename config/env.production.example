# 生产环境配置示例
# 复制到腾讯云服务器：$HOME/medipolicyai/shared/.env

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL_NAME=gpt-5.2
LLM_TIMEOUT=60.0

SIRCHMUNK_PUBLIC_SERVICE=true
SIRCHMUNK_SERVE_UI=true
UI_THEME=light
UI_LANGUAGE=zh
SIRCHMUNK_SEARCH_PATHS=/app/policy-docs
SIRCHMUNK_ALLOWED_PATHS=/app/policy-docs
SIRCHMUNK_UPLOAD_ENABLED=false
SIRCHMUNK_DEBUG=false

CHAT_HISTORY_MAX_TURNS=0
CHAT_HISTORY_MAX_TOKENS=32000

# 宿主机端口，docker-compose.prod.yml 默认映射为 APP_PORT:8584
APP_PORT=8584

# 国内服务器如果拉 GitHub release 慢，可以设置代理前缀，例如：
# GITHUB_PROXY=https://ghfast.top/
GITHUB_PROXY=
PRELOAD_EMBEDDING_MODEL=false

# 腾讯云服务器默认使用国内镜像源加速 Docker 本地构建。
APT_MIRROR=http://mirrors.tencentyun.com/debian
APT_SECURITY_MIRROR=http://mirrors.tencentyun.com/debian-security
PYPI_INDEX_URL=https://mirrors.cloud.tencent.com/pypi/simple
NPM_REGISTRY=https://registry.npmmirror.com
